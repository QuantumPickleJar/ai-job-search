# Container ownership. The setup wizard detects these on Linux.
PUID=1000
PGID=1000

# Host interface used by the Compose port publication.
# Keep localhost for Tailscale Serve, Cloudflare Tunnel, or all-in-one development.
# Use a private LAN address only after reviewing docs/remote-access.md.
APP_HOST=127.0.0.1
APP_PORT=3927
APP_DATA_DIR=/app/data

# Private LAN or Tailscale address of the Windows Ollama workstation.
# Never use a public hostname or forwarded public port.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# Replace this placeholder in `.env` with a strong, unique value.
APP_API_KEY=replace-with-a-strong-random-secret

# Set true only after a private tailnet/VPN or Access-protected tunnel is ready.
ENABLE_REMOTE_MODE=false
