# Host-side Compose settings.
# Use `id -u` and `id -g` on the Raspberry Pi.
APP_UID=1000
APP_GID=1000

# Keep localhost for Tailscale Serve or Cloudflare Tunnel.
# For trusted LAN access, use the Pi's private address, such as 192.168.1.20.
APP_BIND_ADDRESS=127.0.0.1

# Service settings.
APP_HOST=0.0.0.0
APP_PORT=3927
APP_DATA_DIR=/app/data

# Private LAN or Tailscale address of the Windows Ollama workstation.
# Never use a public hostname or forwarded public port.
OLLAMA_BASE_URL=http://192.168.1.50:11434
OLLAMA_MODEL=qwen2.5:14b

# Replace this placeholder in `.env` with a strong, unique value.
APP_API_KEY=replace-with-a-strong-random-secret

# Set true only after a private tailnet/VPN or Access-protected tunnel is ready.
ENABLE_REMOTE_MODE=false
