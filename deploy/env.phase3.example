APP_HOST=0.0.0.0
APP_PORT=3927
APP_DATA_DIR=/app/data

# Point this at the Windows 11 machine running Ollama.
# Examples:
# OLLAMA_BASE_URL=http://192.168.1.50:11434
# OLLAMA_BASE_URL=http://100.x.y.z:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

OLLAMA_MODEL=qwen2.5:14b

# Change this before exposing the service beyond localhost.
APP_API_KEY=change-me

# Keep false until authentication and remote access are configured.
ENABLE_REMOTE_MODE=false
