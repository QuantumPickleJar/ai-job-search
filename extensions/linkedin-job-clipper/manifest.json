{
  "manifest_version": 3,
  "name": "LinkedIn Job Clipper",
  "version": "0.1.0",
  "description": "Capture the currently open LinkedIn job posting and save it to the local ai-job-search intake server.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save LinkedIn job"
  },
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:3927/*",
    "http://127.0.0.1:3927/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://linkedin.com/jobs/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
